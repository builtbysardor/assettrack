# =============================================================================
# AssetTrack — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any file containing real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required)
# PostgreSQL connection string used by Prisma (prisma/schema.prisma).
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/assettrack"

# -----------------------------------------------------------------------------
# Authentication (required)
# Used by NextAuth.js (lib/auth.ts).
# AUTH_SECRET must be at least 32 random characters.
# Generate one with: openssl rand -base64 32
# Note: some deployments expose this as NEXTAUTH_SECRET — both are accepted
# by NextAuth v5+, but AUTH_SECRET is the canonical name.
# -----------------------------------------------------------------------------
AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# LDAP integration (optional — lib/ldap.ts)
# Set LDAP_ENABLED=true to connect to a real LDAP/Active Directory server.
# When false (default) the application runs in simulation mode: LDAP
# operations are logged but no real directory changes are made.
# -----------------------------------------------------------------------------
LDAP_ENABLED="false"
LDAP_URL="ldap://localhost:389"
LDAP_BIND_DN="cn=admin,dc=company,dc=com"
LDAP_BIND_PASSWORD="change-me"
LDAP_BASE_DN="dc=company,dc=com"

# -----------------------------------------------------------------------------
# Email / SMTP (optional — lib/email.ts)
# Set EMAIL_ENABLED=true to send real emails (welcome, offboarding notices).
# When false (default) emails are logged to the console instead.
# SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASS map directly to the Nodemailer
# transport. EMAIL_FROM is the display address used in the From header.
# -----------------------------------------------------------------------------
EMAIL_ENABLED="false"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="change-me"
# EMAIL_FROM is the human-readable sender shown in email clients.
# If unset, SMTP_USER is used as the From address.
EMAIL_FROM="AssetTrack <noreply@example.com>"
