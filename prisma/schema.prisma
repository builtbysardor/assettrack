generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  HR
  MANAGER
  VIEWER
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  RETIRED
  MISSING
}

enum EmployeeStatus {
  PENDING
  ONBOARDING
  ACTIVE
  OFFBOARDING
  INACTIVE
}

enum TaskType {
  CREATE_LDAP_ACCOUNT
  SEND_WELCOME_EMAIL
  SETUP_EMAIL_ACCOUNT
  ASSIGN_EQUIPMENT
  GRANT_SYSTEM_ACCESS
  COMPLETE_PAPERWORK
  MANAGER_INTRODUCTION
  IT_ORIENTATION
  REVOKE_LDAP_ACCOUNT
  REVOKE_SYSTEM_ACCESS
  COLLECT_EQUIPMENT
  FINAL_PAYROLL
  EXIT_INTERVIEW
  KNOWLEDGE_TRANSFER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  SKIPPED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         Role       @default(VIEWER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assets       Asset[]    @relation("CreatedBy")
  auditLogs    AuditLog[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String   @default("box")
  color     String   @default("#10B981")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assets    Asset[]
}

model Location {
  id          String   @id @default(cuid())
  building    String
  room        String
  floor       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assets      Asset[]
}

model Asset {
  id             String      @id @default(cuid())
  tag            String      @unique
  name           String
  serialNumber   String?
  categoryId     String
  locationId     String
  assignedTo     String?
  status         AssetStatus @default(ACTIVE)
  purchaseDate   DateTime?
  warrantyExpiry DateTime?
  cost           Decimal?    @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  createdById    String
  category       Category    @relation(fields: [categoryId], references: [id])
  location       Location    @relation(fields: [locationId], references: [id])
  createdBy      User        @relation("CreatedBy", fields: [createdById], references: [id])

  @@index([status])
  @@index([tag])
  @@index([warrantyExpiry])
  @@index([categoryId])
  @@index([locationId])
  @@index([createdById])
}

model Department {
  id          String     @id @default(cuid())
  name        String     @unique
  code        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

model Employee {
  id               String           @id @default(cuid())
  employeeId       String           @unique
  firstName        String
  lastName         String
  email            String           @unique
  phone            String?
  departmentId     String
  department       Department       @relation(fields: [departmentId], references: [id])
  position         String
  managerId        String?
  manager          Employee?        @relation("Reports", fields: [managerId], references: [id])
  reports          Employee[]       @relation("Reports")
  startDate        DateTime
  endDate          DateTime?
  status           EmployeeStatus   @default(PENDING)
  ldapDn           String?
  ldapUsername     String?
  ldapCreated      Boolean          @default(false)
  welcomeEmailSent Boolean          @default(false)
  avatarUrl       String?
  notes           String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  onboardingTasks  OnboardingTask[]
  offboardingTasks OffboardingTask[]
  auditLogs        AuditLog[]

  @@index([status])
  @@index([departmentId])
}

model OnboardingTask {
  id          String     @id @default(cuid())
  employeeId  String
  employee    Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        TaskType
  status      TaskStatus @default(PENDING)
  description String?
  assignedTo  String?
  dueDate     DateTime?
  completedAt DateTime?
  metadata    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([employeeId])
  @@index([status])
}

model OffboardingTask {
  id          String     @id @default(cuid())
  employeeId  String
  employee    Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        TaskType
  status      TaskStatus @default(PENDING)
  description String?
  assignedTo  String?
  dueDate     DateTime?
  completedAt DateTime?
  metadata    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([employeeId])
  @@index([status])
}

model AuditLog {
  id         String    @id @default(cuid())
  entity     String
  entityId   String
  action     String
  changes    Json?
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
  createdAt  DateTime  @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([employeeId])
}
